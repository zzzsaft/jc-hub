    "product-config-agent:archive-feature-restore": "tsx apps/server/src/modules/productConfigAgent/scripts/restoreArchiveFeatureBackfill.ts",
    "product-config-agent:archive-feature-optimize": "tsx apps/server/src/modules/productConfigAgent/scripts/runArchiveFeatureOptimizationLoop.ts",
    "product-config-agent:archive-feature-optimize-rollback": "tsx apps/server/src/modules/productConfigAgent/scripts/rollbackArchiveFeatureOptimizationBatch.ts",
    "product-config-agent:archive-search-diagnostics": "tsx apps/server/src/modules/productConfigAgent/scripts/auditArchiveSearchDiagnostics.ts",
    "product-config-agent:archive-search-acceptance": "tsx apps/server/src/modules/productConfigAgent/scripts/runArchiveSearchAcceptance.ts",
    "product-config-agent:progress-ledger": "tsx apps/server/src/modules/productConfigAgent/scripts/reportProgressLedger.ts",
    "product-config-agent:parser-reparse-compare": "tsx apps/server/src/modules/productConfigAgent/scripts/reportExcelParserReparseCompare.ts",
    "product-config-agent:erp-identity-lookup": "tsx apps/server/src/modules/productConfigAgent/scripts/lookupErpIdentityCandidates.ts",
    "product-config-agent:erp-identity-ledger": "tsx apps/server/src/modules/productConfigAgent/scripts/auditErpIdentityLedger.ts",
    "product-config-agent:product-type-discovery-audit": "tsx apps/server/src/modules/productConfigAgent/scripts/auditProductTypeDiscovery.ts",
    "product-config-agent:golden-set-v1": "tsx apps/server/src/modules/productConfigAgent/scripts/buildProductConfigGoldenSetV1.ts",
