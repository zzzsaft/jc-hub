{
  "name": "jc-hub",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "tsx watch apps/server/src/index.ts",
    "dev:server": "tsx watch apps/server/src/index.ts",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p apps/server/tsconfig.json",
    "build:web": "npm run build -w apps/web",
    "start": "node apps/server/build/index.js",
    "test": "node apps/server/test/run-tests.mjs",
    "lint:web": "npm run lint -w apps/web",
    "prisma:generate": "prisma generate --schema apps/server/prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema apps/server/prisma/schema.prisma",
    "product-config-agent:worker": "tsx apps/server/src/modules/productConfigAgent/scripts/runWorker.ts",
    "product-config-agent:parse-production-detail-excels": "tsx apps/server/src/modules/productConfigAgent/scripts/parseProductionDetailExcels.ts",
    "product-config-agent:reparse-excel-configs": "tsx apps/server/src/modules/productConfigAgent/scripts/reparseExcelConfigsAndCompare.ts",
    "product-config-agent:report-duplicate-production-detail-documents": "tsx apps/server/src/modules/productConfigAgent/scripts/reportDuplicateProductionDetailDocuments.ts",
    "product-config-agent:apply-duplicate-production-detail-documents": "tsx apps/server/src/modules/productConfigAgent/scripts/reportDuplicateProductionDetailDocuments.ts --apply",
    "product-config-agent:normalize-full": "tsx apps/server/src/modules/productConfigAgent/scripts/runFullNormalizationWithMasterData.ts",
    "product-config-agent:concept-resolver-backfill": "tsx apps/server/src/modules/productConfigAgent/scripts/runConceptResolverBackfill.ts",
    "product-config-agent:concept-resolver-audit": "tsx apps/server/src/modules/productConfigAgent/scripts/runConceptResolverDictionaryAudit.ts",
    "product-config-agent:audit-dictionary-candidate-dedupe": "tsx apps/server/src/modules/productConfigAgent/scripts/auditDictionaryCandidateDedupe.ts",
    "product-config-agent:phase1-snapshot-finalize": "tsx apps/server/src/modules/productConfigAgent/scripts/finalizeDictionaryCandidatePhase1Snapshot.ts",
    "product-config-agent:refresh-master-data-bindings": "tsx apps/server/src/modules/productConfigAgent/scripts/refreshNormalizationArchivesWithMasterData.ts",
    "product-config-agent:consolidate-qualifier-terms": "tsx apps/server/src/modules/productConfigAgent/scripts/consolidateQualifierTermTypes.ts",
    "product-config-agent:reextract-cross-concept": "tsx apps/server/src/modules/productConfigAgent/scripts/reextractCrossConceptCandidates.ts",
    "product-config-agent:upgrade-excel-blocks-options": "tsx apps/server/src/modules/productConfigAgent/scripts/upgradeExcelBlocksOptions.ts",
    "product-config-agent:archive-feature-audit": "tsx apps/server/src/modules/productConfigAgent/scripts/auditArchiveFeatureCoverage.ts",
