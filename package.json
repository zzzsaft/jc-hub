    "sql-agent:observe-rollout": "tsx apps/server/src/modules/erpSqlAgent/scripts/observeRollout.ts",
    "sql-agent:evaluate": "npm run sql-template:retrieval-eval -- --out=tmp/sql-template-retrieval-eval.json --md-out=tmp/sql-template-retrieval-eval.md --compact-out=tmp/sql-template-retrieval-eval.compact.json",
    "sql-template:import-cpt": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/importFineReportSql.ts",
    "sql-template:analyze": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/analyzeSqlTemplates.ts",
    "sql-template:family-sample": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/sampleSqlFamilies.ts",
    "sql-family:promote-assets": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/promoteSqlFamilyAssets.ts",
    "sql-family:auto-promote": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/autoPromoteSqlFamilies.ts",
    "sql-family:verify-assets": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/verifySqlFamilyAssets.ts",
    "sql-template:promote": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/promoteSqlTemplate.ts",
    "sql-template:validate-drafts": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/validateSqlTemplateDrafts.ts",
    "sql-template:build-reference-index": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/buildSqlDatasetReferenceIndex.ts",
    "sql-template:build-reference-embeddings": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/buildSqlDatasetReferenceEmbeddings.ts",
    "sql-template:audit-reference-index": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/auditSqlDatasetReferenceIndex.ts",
    "sql-template:search-reference": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/searchSqlDatasetReferences.ts",
    "sql-template:debug-draft": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/debugSqlTemplateDraft.ts",
    "sql-template:retrieval-eval": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/evaluateSqlTemplateRetrieval.ts",
    "sql-template:guard": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/guardSqlTemplate.ts",
    "sql-template:approve": "tsx apps/server/src/modules/erpSqlAgent/templates/scripts/approveSqlTemplate.ts",
    "jdy:sync-crm-customers": "tsx apps/server/src/integration/jdy/scripts/syncCrmCustomers.ts"
  },
  "dependencies": {
    "@mastra/core": "^1.50.0",
    "@prisma/client": "^5.22.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/sm-crypto": "^0.3.4",
    "adm-zip": "^0.5.16",
    "axios": "^1.6.7",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "node-sql-parser": "^5.4.0",
    "openai": "^6.34.0",
    "sm-crypto": "^0.4.0",
    "winston": "^3.13.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20.17.10",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
