      "sqlPreview": "select year(ih.ApplyDate) as n ,year(ih.ApplyDate)*100+month(ih.ApplyDate)as ny ,a.OrderNum,b.OrderLine,b.PartNum,b.LineDesc,f.Name 客户名称,ih.LegalNumber 法定编号 ,ih.InvoiceNum ,b.sellingquantity sl ,(CASE WHEN id.TaxRegionCode <>'' THEN id.DocinunitPrice *id.SellingShipQty ELSE id.DocExtPrice END)/10000 as \"下单含税价\" ,(CASE WHEN id.TaxRegionCode <>'' THEN id.DocinunitPrice *id.SellingShipQty ELSE id.DocExtPrice END)/1.13/10000 as \"下单未税价\" ,case when a.CustNum='7214' then N'外销' else N'内销' end as type ,f.State,f.City ,case when charindex(N'上海',f.State)>0 or charindex(N'山东',f.State)>0 or charindex(N'江苏',f.State)>0 or charindex(N'安徽',f.State)>0 or charindex(N'江西',f.State)>0 or charindex(N'浙江',f.State)>0 or charindex(N'福建',f.State)>0 or charindex(N'台湾',f.State)>0 then N'华东' when charindex(N'广西',f.State)>0 or charindex(N'广东',f.State)>0 or charindex(N'海南',f.State)>0 or charindex(N'香港',f.State)>0 or charindex(N'澳门',f.State)>0 then N'华南' when charindex(N'北京',f.State)>0 or charindex(N'天津',f.State)>0 or charindex(N'河北',f.State)>0 or charindex(N'山西',f.State)>0 or charindex(N'内蒙',f.State)>0 then N'华北' when charindex(N'河南',f.State)>0 or charindex(N'湖北',f.State)>0 or charindex(N'湖南',f.State)>0 then N'华中' when charindex(N'重庆',f.State)>0 or charindex(N'四川',f.State)>0 or charindex(N'贵州',f.State)>0 or charindex(N'云南',f.State)>0 or charindex(N'西藏',f.State)>0 then N'西南' when charindex(N'陕西',f.State)>0 or charindex(N'甘肃',f.State)>0 or charindex(N'青海',f.State)>0 or charindex(N'宁夏',f.State)>0 or charindex(N'新疆',f.State)>0 then N'西北' when charindex(N'辽宁',f.State)>0 or charindex(N'吉林',f.State)>0 or charindex(N'黑龙江',f.State)>0 then N'东北' when a.CustNum='7214' then N'国外' else N'未维护' end as 地区 ,isnull(nullif(e.Character05,''),N'其他') 行业分类 ,case when e.ProdCode='0910' then N'平模' when e.ProdCode='091020' then N'圆模' when e.ProdCode='091031' then N'涂布' else N'配件' end as 事业部 ,case when charindex(N'',g.Description)>0 then N'维修费' else g.Description end 产品 ,h.MtlUnitCost 物料成本,h.LbrUnitCost 人工成本,h.SubUnitCost 外协成本,h.BurUnitCost 制费成本 ,case when b.DocInUnitPrice=0 then b.DocUnitPrice else b.DocInUnitPrice end/1.13-h.MtlUnitCost-h.LbrUnitCost-h.SubUnitCost-h.BurUnitCost 毛利 ,case when case when b.DocInUnitPrice=0 then b.DocUnitPrice else b.DocInUnitPrice end =0 then 0 else (case when b.DocInUnitPrice=0 then b.DocUnitPrice else b.DocInUnitPrice end/1.13-h.MtlUnitCost-h.LbrUnitCost-h.SubUnitCost-h.BurUnitCost)/(case when b.DocInUnitPrice=0 then b.DocUnitPrice else b.DocInUnitPrice end/1.13) end 毛利率 ,case when b.SalesCatID = '0002' then N'维修产品' when b.SalesCatID = '0003' then N'零售产品' else N'新开产品' end as 类型 from Erp.InvcHead ih left join Erp.InvcDtl id ON ih.Company=id.Company AND ih.InvoiceNum=id.InvoiceNum left join OrderDtl b on b.Company=id.Company and b.OrderNum=id.OrderNum and b.OrderLine=id.OrderLine left join erp.OrderHed a on a.OrderNum=b.OrderNum and a.Company=b.Company left join erp.JobProd c on c.Company=b.Company and c.OrderNum=b.OrderNum and c.OrderLine=b.OrderLine left join erp.JobHead"
