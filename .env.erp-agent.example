# ERP SQL Agent local-only configuration.
# Copy to .env.erp-agent for local development. The real .env.erp-agent is gitignored.
# Load order: .env -> .env.dev (non-production override) -> .env.erp-agent (fills only unset keys) -> process env.
# Production must inject these values from a secret/config manager; do not commit real secrets.

ERP_SQL_ACCESS_POLICY_JSON='{"users":{}}'
ERP_SQL_AGENT_INTENT_ENABLED=true
ERP_SQL_AGENT_LLM_GENERATOR_ENABLED=true
ERP_SQL_AGENT_EXECUTE_GENERATED_SQL=false
ERP_SQL_AGENT_EXECUTE_APPROVED_TEMPLATES=true
# Diagnostic only: exact "true" lets qualifying composite finance plans inspect existing draft/disabled atomic metrics.
# All metric structure, access, SQL and runtime guards remain enabled; successful bypass results are estimates.
ERP_SQL_DIAGNOSTIC_BYPASS_COMPOSITE_CAPABILITY=false
ERP_SQL_DISABLED_FAMILIES=family_008,family_080
ERP_SQL_DISABLED_TEMPLATE_IDS=

ERP_SQL_AGENT_TRACE_ENABLED=true
ERP_AUDIT_RAW_PAYLOADS_ENABLED=false
ERP_AUDIT_RAW_PAYLOADS_TRUSTED=false
AGENT_RUNTIME_RAW_PAYLOADS_ENABLED=false
ERP_RESULT_NARRATOR_EXTERNAL_ENABLED=false
ERP_RESULT_NARRATOR_EXTERNAL_TRUSTED=false
ERP_RESULT_NARRATOR_EXTERNAL_RAW_ROWS_ENABLED=false
ERP_AUDIT_RETENTION_DAYS=90

LLM_CONCURRENCY_LIMIT=12
LLM_MAX_QUEUE=64
AGENT_RUNTIME_CONCURRENCY_LIMIT=2
AGENT_RUNTIME_MAX_QUEUE=8
ERP_SQL_DB_CONCURRENCY=6
ERP_SQL_DB_MAX_QUEUE=32
ERP_SQL_GUARD_CONCURRENCY=4
ERP_SQL_GUARD_MAX_QUEUE=32
ERP_QUERY_CONCURRENCY=4
ERP_QUERY_MAX_QUEUE=16
AUDIT_DB_CONCURRENCY=4
AUDIT_DB_MAX_QUEUE=100

ERP_SQL_AGENT_TOTAL_DEADLINE_MS=120000
ERP_SQL_LLM_STAGE_TIMEOUT_MS=15000
ERP_SQL_GENERATE_TIMEOUT_MS=60000
ERP_SQL_GUARD_STAGE_TIMEOUT_MS=10000
ERP_SQL_REPAIR_TIMEOUT_MS=30000
ERP_SQL_DB_STAGE_TIMEOUT_MS=10000
ERP_SQL_REFERENCE_STAGE_TIMEOUT_MS=5000
ERP_SQL_LLM_FIRST_TOKEN_SLOW_MS=5000
ERP_SQL_LLM_STREAM_SLOW_MS=30000
ERP_SQL_REFERENCE_SOFT_TIMEOUT_MS=2500
ERP_SQL_REFERENCE_EMBEDDING_TIMEOUT_MS=1200
ERP_QUERY_CLIENT_TIMEOUT_MS=15000
ERP_QUERY_STAGE_TIMEOUT_MS=20000

ERP_SQL_SCHEMA_SNAPSHOT_VERSION=unknown
ERP_SQL_TEMPLATE_CACHE_TTL_MS=60000
ERP_QUERY_BACKEND_URL=auto
ERP_QUERY_LAN_BACKEND_URL=http://192.168.0.216:780
ERP_QUERY_PUBLIC_BACKEND_URL=http://122.226.146.110:780
ERP_QUERY_API_KEY=
ERP_QUERY_CRYPTO_SECRET=
# Verified operation assets are fail-closed by default. Enable independently only after deployment approval.
ERP_SQL_OPERATION_LABOR_REPORTING_ENABLED=false
ERP_SQL_OPERATION_MASTER_DATA_ENABLED=false
