model User {
  id               String     @id @default(cuid())
  wecomUserId      String?    @map("wecom_user_id")
  erpUserId        String?    @map("erp_user_id")
  employeeNo       String?    @map("employee_no")
  username         String?    @unique
  passwordHash     String?    @map("password_hash")
  name             String
  nameInitials     String?    @map("name_initials")
  avatar           String?
  gender           String?
  qrCode           String?    @map("qr_code")
  mobile           String?
  email            String?
  bizMail          String?    @map("biz_mail")
  address          String?
  department       Json?
  departmentOrder  Json?      @map("department_order")
  position         String?
  isLeaderInDept   Json?      @map("is_leader_in_dept")
  directLeader     Json?      @map("direct_leader")
  telephone        String?
  alias            String?
  extattr          Json?
  wecomStatus      Int?       @map("wecom_status")
  externalProfile  Json?      @map("external_profile")
  externalPosition String?    @map("external_position")
  openUserid       String?    @map("open_userid")
  mainDepartment   Int?       @map("main_department")
  teamName         String?    @map("team_name")
  status           String     @default("active")
  lastLoginAt      DateTime?  @map("last_login_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  userRoles        UserRole[]
  permissionOverrides UserPermissionOverride[]

  @@unique([wecomUserId])
  @@unique([erpUserId])
  @@map("users")
  @@schema("identity")
}

model Role {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  userRoles UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
  @@schema("identity")
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("identity")
}

model Permission {
  id              String                   @id @default(cuid())
  code            String                   @unique
  resource        String
  action          String
  name            String
  description     String?
  enabled         Boolean                  @default(true)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  rolePermissions RolePermission[]
  userOverrides   UserPermissionOverride[]

  @@index([resource])
  @@map("permissions")
  @@schema("identity")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("identity")
}

model UserPermissionOverride {
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  effect       String
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permission_overrides")
  @@schema("identity")
}

model WecomDepartment {
  id               String                @id @default(cuid())
  clientId         String                @map("client_id")
  departmentId     Int                   @map("department_id")
  name             String?
  nameEn           String?               @map("name_en")
  departmentLeader Json?                 @map("department_leader")
  parentId         Int                   @map("parent_id")
  order            BigInt?               @map("order_value")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  users            WecomUserDepartment[]

  @@unique([clientId, departmentId])
  @@index([clientId, parentId])
  @@map("wecom_departments")
  @@schema("identity")
}

model WecomUserDepartment {
  clientId     String           @map("client_id")
  userId       String           @map("user_id")
  departmentId Int              @map("department_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  department   WecomDepartment? @relation(fields: [clientId, departmentId], references: [clientId, departmentId], onDelete: Cascade)

  @@id([clientId, userId, departmentId])
  @@index([clientId, departmentId])
  @@index([userId])
  @@map("wecom_user_departments")
  @@schema("identity")
}
