generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["agent", "erp_agent", "production_config_agent", "identity", "integration", "hr_performance_agent"]
}

model AgentSession {
  id            BigInt   @id @default(autoincrement())
  agentType     String   @default("generalAgent") @map("agent_type") @db.VarChar(100)
  title         String?
  ownerUserId   String?  @map("owner_user_id")
  status        String   @default("active") @db.VarChar(50)
  metadataJsonb Json     @default("{}") @map("metadata_jsonb")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([agentType])
  @@index([ownerUserId])
  @@index([status])
  @@map("agent_sessions")
  @@schema("agent")
}

model AgentMessage {
  id           BigInt   @id @default(autoincrement())
  sessionId    BigInt   @map("session_id")
  role         String   @db.VarChar(50)
  content      String?
  contentJsonb Json?    @map("content_jsonb")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@index([role])
  @@map("agent_messages")
  @@schema("agent")
}

model AgentRun {
  id                  BigInt   @id @default(autoincrement())
  sessionId           BigInt   @map("session_id")
  agentType           String   @map("agent_type") @db.VarChar(100)
  intent              String?  @db.VarChar(100)
  status              String   @default("running") @db.VarChar(50)
  plannerJsonb        Json     @default("{}") @map("planner_jsonb")
  contextSummaryJsonb Json     @default("{}") @map("context_summary_jsonb")
  errorJsonb          Json?    @map("error_jsonb")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([sessionId, createdAt])
  @@index([agentType])
  @@index([status])
  @@map("agent_runs")
  @@schema("agent")
}

model AgentToolCall {
  id          BigInt   @id @default(autoincrement())
  runId       BigInt   @map("run_id")
  stepId      String   @map("step_id") @db.VarChar(100)
  toolName    String   @map("tool_name") @db.VarChar(100)
  argsJsonb   Json     @default("{}") @map("args_jsonb")
  resultJsonb Json?    @map("result_jsonb")
  status      String   @default("running") @db.VarChar(50)
  errorJsonb  Json?    @map("error_jsonb")
  durationMs  Int?     @map("duration_ms")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([runId, stepId])
  @@index([toolName])
  @@index([status])
  @@map("agent_tool_calls")
  @@schema("agent")
}

model AgentGeneratedConfig {
  id                   BigInt    @id @default(autoincrement())
  runId                BigInt    @map("run_id")
  sessionId            BigInt    @map("session_id")
  title                String?
  status               String    @default("draft") @db.VarChar(50)
  configJsonb          Json      @default("{}") @map("config_jsonb")
  validationJsonb      Json      @default("{}") @map("validation_jsonb")
  shareToken           String?   @unique @map("share_token")
  shareTokenExpiresAt  DateTime? @map("share_token_expires_at")
  shareTokenRevokedAt  DateTime? @map("share_token_revoked_at")
  ownerUserId          String?   @map("owner_user_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([runId])
  @@index([sessionId])
  @@index([ownerUserId])
  @@index([status])
  @@index([shareTokenExpiresAt])
  @@map("agent_generated_configs")
  @@schema("agent")
}

model LlmCallLog {
  id          BigInt    @id @default(autoincrement())
  provider    String    @db.VarChar(50)
  model       String    @db.VarChar(100)
  purpose     String    @db.VarChar(100)
  inputJsonb  Json      @map("input_jsonb")
  outputJsonb Json?     @map("output_jsonb")
  error       String?
  status      String    @default("pending") @db.VarChar(30)
  latencyMs   Int?      @map("latency_ms")
  startedAt   DateTime  @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([provider])
  @@index([model])
  @@index([purpose])
  @@index([status])
  @@map("llm_call_logs")
  @@schema("agent")
}

model ProductDocument {
  id              BigInt   @id @default(autoincrement())
  fileName        String?  @map("file_name")
  fileHash        String   @map("file_hash")
  filePath        String   @map("file_path")
  source          String?
  status          String   @default("uploaded") @db.VarChar(50)
  dictionaryDirty Boolean  @default(false) @map("dictionary_dirty")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([fileHash])
  @@index([createdAt])
  @@map("documents")
  @@schema("production_config_agent")
}

model DocumentBlock {
  id            BigInt   @id @default(autoincrement())
  documentId    BigInt   @unique @map("document_id")
  blocksJson    Json     @map("blocks_json")
  parserVersion String?  @map("parser_version") @db.VarChar(80)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("document_blocks")
  @@schema("production_config_agent")
}

model ExtractionResult {
  id                       BigInt   @id @default(autoincrement())
  documentId               BigInt   @map("document_id")
  extractionJson           Json     @map("extraction_json")
  normalizedExtractionJson Json?    @map("normalized_extraction_json")
  dictionaryProposals      Json?    @map("dictionary_proposals")
  warnings                 Json?
  llmPlanJson              Json?    @map("llm_plan_json")
  llmModel                 String?  @map("llm_model") @db.VarChar(100)
  promptVersion            String?  @map("prompt_version") @db.VarChar(100)
  dictionaryVersion        BigInt?  @map("dictionary_version")
  status                   String   @default("created") @db.VarChar(50)
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@index([documentId, createdAt])
  @@index([status])
  @@map("extraction_results")
  @@schema("production_config_agent")
}

model DictionaryTermType {
  id                     BigInt   @id @default(autoincrement())
  termType               String   @unique @map("term_type") @db.VarChar(100)
  displayName            String   @map("display_name")
  quoteDisplayName       String?  @map("quote_display_name")
  description            String?
  category               String?  @db.VarChar(100)
  sortOrder              Int      @default(100) @map("sort_order")
  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  applicableProductTypes Json     @default("[\"common\"]") @map("applicable_product_types")
  valueKind              String   @default("enum") @map("value_kind") @db.VarChar(50)
  scope                  String   @default("item") @db.VarChar(50)
  conceptRole            String   @default("config_attribute") @map("concept_role") @db.VarChar(50)
  riskLevel              String   @default("normal") @map("risk_level") @db.VarChar(30)
  baselineTrustTier      String   @default("provisional") @map("baseline_trust_tier") @db.VarChar(30)
  baselineRiskLabels     Json     @default("[]") @map("baseline_risk_labels")
  metadata               Json     @default("{}")

  @@index([isActive], map: "idx_dictionary_term_types_active")
  @@index([applicableProductTypes], map: "idx_dictionary_term_types_applicable_product_types", type: Gin)
  @@index([category], map: "idx_dictionary_term_types_category")
  @@map("dictionary_term_types")
  @@schema("production_config_agent")
}

model DictionaryTerm {
  id                   BigInt   @id @default(autoincrement())
  termType             String   @map("term_type") @db.VarChar(100)
  canonicalValue       String   @map("canonical_value")
  displayName          String?  @map("display_name")
  description          String?
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  scope                String   @default("value") @db.VarChar(50)
  conceptRole          String   @default("enum_value") @map("concept_role") @db.VarChar(50)
  riskLevel            String   @default("normal") @map("risk_level") @db.VarChar(30)
  baselineTrustTier    String   @default("provisional") @map("baseline_trust_tier") @db.VarChar(30)
  baselineRiskLabels   Json     @default("[]") @map("baseline_risk_labels")

  @@unique([termType, canonicalValue], map: "uq_dictionary_terms_type_value")
  @@index([termType], map: "idx_dictionary_terms_term_type")
  @@index([isActive], map: "idx_dictionary_terms_active")
  @@map("dictionary_terms")
  @@schema("production_config_agent")
}

model DocumentDuplicate {
  id                 BigInt   @id @default(autoincrement())
  documentId         BigInt   @map("document_id")
  duplicateDocumentId BigInt  @map("duplicate_document_id")
  duplicateType      String   @default("file_hash") @map("duplicate_type") @db.VarChar(60)
  confidence         Float    @default(1)
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([documentId, duplicateDocumentId, duplicateType])
  @@index([documentId])
  @@index([duplicateDocumentId])
  @@map("document_duplicates")
  @@schema("production_config_agent")
}

model DictionaryCandidate {
  id                     BigInt    @id @default(autoincrement())
  documentId             BigInt?   @map("document_id")
  extractionResultId     BigInt?   @map("extraction_result_id")
  termType               String    @map("term_type") @db.VarChar(100)
  rawValue               String    @map("raw_value")
  normalizedRawValue     String    @map("normalized_raw_value")
  proposedCanonicalValue String?   @map("proposed_canonical_value")
  proposedTermId         BigInt?   @map("proposed_term_id")
  reason                 String?
  evidence               Json?
  confidence             Decimal?  @db.Decimal(4, 3)
  status                 String    @default("pending") @db.VarChar(30)
  reviewedBy             String?   @map("reviewed_by")
  reviewedAt             DateTime? @map("reviewed_at") @db.Timestamp(6)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  sourceProductType      String    @default("unknown") @map("source_product_type") @db.VarChar(100)
  itemIndex              Int?      @map("item_index")
  resolverStatus         String?   @map("resolver_status") @db.VarChar(30)
  resolverRoute          String?   @map("resolver_route") @db.VarChar(50)
  resolverScore          Decimal?  @map("resolver_score") @db.Decimal(5, 3)
  resolverRiskLevel      String?   @map("resolver_risk_level") @db.VarChar(30)
  resolverDecisionJsonb  Json?     @map("resolver_decision_jsonb")
  lastResolvedAt         DateTime? @map("last_resolved_at") @db.Timestamp(6)

  @@unique([termType, normalizedRawValue, status], map: "uq_dictionary_candidates_term_value_status")
  @@index([documentId], map: "idx_dictionary_candidates_document")
  @@index([extractionResultId], map: "idx_dictionary_candidates_extraction")
  @@index([termType, normalizedRawValue, status], map: "idx_dictionary_candidates_human_review_lookup")
  @@index([id], map: "idx_dictionary_candidates_id_numeric")
  @@index([termType, normalizedRawValue], map: "idx_dictionary_candidates_lookup")
  @@index([status], map: "idx_dictionary_candidates_status")
  @@map("dictionary_candidates")
  @@schema("production_config_agent")
}

model DictionaryCandidateOccurrence {
  id                 BigInt   @id @default(autoincrement())
  candidateType      String   @map("candidate_type") @db.VarChar(30)
  candidateId        BigInt   @map("candidate_id")
  documentId         BigInt   @map("document_id")
  extractionResultId BigInt   @map("extraction_result_id")
  itemIndex          Int      @map("item_index")
  fieldName          String   @map("field_name")
  rawValue           String?  @map("raw_value")
  evidence           Json?
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  sourceProductType  String   @default("unknown") @map("source_product_type") @db.VarChar(100)
  rawValueHash       String?  @map("raw_value_hash") @db.VarChar(64)
  occurrenceHash     String?  @unique @map("occurrence_hash") @db.VarChar(64)

  @@unique([candidateType, candidateId, extractionResultId, itemIndex, fieldName], map: "uq_dictionary_candidate_occurrences_context")
  @@index([candidateType, candidateId], map: "idx_dictionary_candidate_occurrences_candidate")
  @@index([candidateType, candidateId, createdAt(sort: Desc)], map: "idx_dictionary_candidate_occurrences_candidate_created")
  @@index([documentId], map: "idx_dictionary_candidate_occurrences_document")
  @@index([extractionResultId], map: "idx_dictionary_candidate_occurrences_extraction")
  @@index([extractionResultId, itemIndex], map: "idx_dictionary_candidate_occurrences_item_context")
  @@index([rawValue], map: "idx_dictionary_candidate_occurrences_raw_value")
  @@map("dictionary_candidate_occurrences")
  @@schema("production_config_agent")
}

model DictionarySuggestion {
  id             BigInt   @id @default(autoincrement())
  termType       String   @map("term_type") @db.VarChar(100)
  candidateId    BigInt?  @map("candidate_id")
  suggestedValue String   @map("suggested_value")
  suggestionType String   @default("create") @map("suggestion_type") @db.VarChar(60)
  status         String   @default("pending") @db.VarChar(40)
  score          Float    @default(0)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([termType, status])
  @@index([candidateId])
  @@map("dictionary_suggestions")
  @@schema("production_config_agent")
}

model DictionarySplit {
  id          BigInt   @id @default(autoincrement())
  termType    String   @map("term_type") @db.VarChar(100)
  sourceValue String   @map("source_value")
  partsJson   Json     @default("[]") @map("parts_json")
  status      String   @default("pending") @db.VarChar(40)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([termType, status])
  @@map("dictionary_splits")
  @@schema("production_config_agent")
}

model DictionaryAlias {
  id                 BigInt    @id @default(autoincrement())
  termId             BigInt    @map("term_id")
  termType           String    @map("term_type") @db.VarChar(100)
  aliasValue         String    @map("alias_value")
  normalizedAlias    String    @map("normalized_alias")
  confidence         Float     @default(1)
  source             String    @default("manual") @db.VarChar(50)
  usageCount         Int       @default(0) @map("usage_count")
  lastSeenAt         DateTime? @map("last_seen_at")
  riskLevel          String    @default("normal") @map("risk_level") @db.VarChar(30)
  baselineTrustTier  String    @default("provisional") @map("baseline_trust_tier") @db.VarChar(30)
  baselineRiskLabels Json      @default("[]") @map("baseline_risk_labels")
  note               String?
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@unique([termType, normalizedAlias])
  @@index([termId])
  @@index([termType, normalizedAlias, isActive])
  @@map("dictionary_aliases")
  @@schema("production_config_agent")
}

model DictionaryTermTypeAlias {
  id                BigInt    @id @default(autoincrement())
  termType          String    @map("term_type") @db.VarChar(100)
  aliasValue        String    @map("alias_name")
  normalizedAlias   String    @unique(map: "uq_dictionary_term_type_aliases") @map("normalized_alias_name")
  description       String?
  source            String    @default("manual") @db.VarChar(50)
  usageCount        Int       @default(0) @map("usage_count")
  lastSeenAt        DateTime? @map("last_seen_at") @db.Timestamp(6)
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  baselineTrustTier String    @default("provisional") @map("baseline_trust_tier") @db.VarChar(30)
  baselineRiskLabels Json    @default("[]") @map("baseline_risk_labels")

  @@index([normalizedAlias, isActive], map: "idx_dictionary_term_type_aliases_lookup")
  @@index([termType], map: "idx_dictionary_term_type_aliases_term_type")
  @@map("dictionary_term_type_aliases")
  @@schema("production_config_agent")
}

model DictionaryUnitAlias {
  id              BigInt    @id @default(autoincrement())
  canonicalUnit   String    @map("canonical_unit")
  displayUnit     String?   @map("display_unit")
  aliasValue      String    @map("alias_value")
  normalizedAlias String    @unique @map("normalized_alias")
  source          String    @default("manual") @db.VarChar(50)
  usageCount      Int       @default(0) @map("usage_count")
  lastSeenAt      DateTime? @map("last_seen_at")
  note            String?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([canonicalUnit])
  @@index([normalizedAlias, isActive])
  @@map("dictionary_unit_aliases")
  @@schema("production_config_agent")
}

model DictionaryUnitCandidate {
  id                    BigInt    @id @default(autoincrement())
  documentId            BigInt?   @map("document_id")
  extractionResultId    BigInt?   @map("extraction_result_id")
  termType              String?   @map("term_type") @db.VarChar(100)
  rawValue              String    @map("raw_value")
  rawUnit               String    @map("raw_unit")
  normalizedRawUnit     String    @map("normalized_raw_unit")
  proposedCanonicalUnit String?   @map("proposed_canonical_unit")
  reason                String?
  evidence              Json?
  status                String    @default("pending") @db.VarChar(30)
  reviewedBy            String?   @map("reviewed_by")
  reviewedAt            DateTime? @map("reviewed_at") @db.Timestamp(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@unique([normalizedRawUnit, status])
  @@index([documentId], map: "idx_dictionary_unit_candidates_document_id")
  @@index([extractionResultId], map: "idx_dictionary_unit_candidates_extraction_result_id")
  @@index([normalizedRawUnit], map: "idx_dictionary_unit_candidates_normalized_raw_unit")
  @@index([status], map: "idx_dictionary_unit_candidates_status")
  @@index([termType], map: "idx_dictionary_unit_candidates_term_type")
  @@map("dictionary_unit_candidates")
  @@schema("production_config_agent")
}

model DictionaryVersion {
  id           BigInt   @id @default(autoincrement())
  versionKey   String   @unique @map("version_key") @db.VarChar(100)
  versionValue BigInt   @default(1) @map("version_value")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([versionKey])
  @@map("dictionary_versions")
  @@schema("production_config_agent")
}

model DictionaryChangeLog {
  id                BigInt   @id @default(autoincrement())
  dictionaryVersion BigInt   @map("dictionary_version")
  source            String   @default("governance") @db.VarChar(80)
  action            String   @db.VarChar(80)
  candidateType     String?  @map("candidate_type") @db.VarChar(30)
  candidateId       BigInt?  @map("candidate_id")
  beforeJsonb       Json?    @map("before_jsonb")
  afterJsonb        Json?    @map("after_jsonb")
  changedBy         String?  @map("changed_by")
  versionKey        String   @default("default") @map("version_key") @db.VarChar(100)
  versionValue      BigInt   @map("version_value")
  entityType        String   @map("entity_type") @db.VarChar(80)
  entityId          String?  @map("entity_id")
  beforeJson        Json?    @map("before_json")
  afterJson         Json?    @map("after_json")
  createdBy         String?  @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([versionKey, versionValue])
  @@index([entityType, entityId])
  @@map("dictionary_change_logs")
  @@schema("production_config_agent")
}

model DictionaryQualifier {
  id           BigInt   @id @default(autoincrement())
  qualifierKey String   @unique(map: "uq_dictionary_qualifiers_key") @map("qualifier_key") @db.VarChar(100)
  kind         String   @db.VarChar(30)
  displayName  String  @map("display_name")
  aliases      Json     @default("[]")
  description  String?
  sortOrder    Int      @default(100) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([isActive], map: "idx_dictionary_qualifiers_is_active")
  @@index([kind], map: "idx_dictionary_qualifiers_kind")
  @@map("dictionary_qualifiers")
  @@schema("production_config_agent")
}

model DictionaryValueSplitSuggestion {
  id          BigInt   @id @default(autoincrement())
  candidateId BigInt   @map("candidate_id")
  termType    String   @map("term_type") @db.VarChar(100)
  rawValue    String   @map("raw_value")
  suggestions Json     @default("[]")
  prompt      String
  model       String   @db.VarChar(100)
  rawResponse Json?    @map("raw_response")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([candidateId], map: "idx_dictionary_value_split_suggestions_candidate")
  @@index([termType], map: "idx_dictionary_value_split_suggestions_term_type")
  @@map("dictionary_value_split_suggestions")
  @@schema("production_config_agent")
}

model SplitResolution {
  id          BigInt   @id @default(autoincrement())
  termType    String   @map("term_type") @db.VarChar(100)
  sourceValue String   @map("source_value")
  resolutionJson Json  @default("{}") @map("resolution_json")
  status      String   @default("active") @db.VarChar(40)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([termType, sourceValue])
  @@index([termType, status])
  @@map("split_resolutions")
  @@schema("production_config_agent")
}

model ConceptResolverEntry {
  id              BigInt   @id @default(autoincrement())
  conceptType     String   @map("concept_type") @db.VarChar(100)
  sourceValue     String   @map("source_value")
  resolvedValue   String?  @map("resolved_value")
  confidence      Float    @default(0)
  status          String   @default("pending") @db.VarChar(40)
  resolverVersion String?  @map("resolver_version") @db.VarChar(80)
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([conceptType, sourceValue])
  @@index([conceptType, status])
  @@map("concept_resolver_entries")
  @@schema("production_config_agent")
}

model ConceptResolverRun {
  id         BigInt    @id @default(autoincrement())
  status     String    @default("running") @db.VarChar(40)
  mode       String    @default("dry_run") @db.VarChar(40)
  inputJson  Json      @default("{}") @map("input_json")
  resultJson Json      @default("{}") @map("result_json")
  errorJson  Json?     @map("error_json")
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("concept_resolver_runs")
  @@schema("production_config_agent")
}

model ConceptPatternReview {
  id          BigInt   @id @default(autoincrement())
